# RedlineIQ Backend Configuration
# Copy this file to .env and fill in your values.

# ─── Required ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_api_key_here

# ─── Server ────────────────────────────────────────────────────
PORT=3001

# ─── Model ─────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── Upload Limits ─────────────────────────────────────────────
# Defaults are conservative for public demo deployments.
# Raise these for internal use where you control who uploads.
MAX_FILE_SIZE_MB=20   # Hard cap enforced by multer at upload time
MAX_PAGES=10          # Checked at upload and again before extraction

# ─── Database ──────────────────────────────────────────────────
# Path to the SQLite database file.
# On Render/Railway, point this at a persistent volume mount
# (e.g. /var/data/redlineiq.db) so data survives redeploys.
# Defaults to ./data/redlineiq.db locally.
DATABASE_PATH=./data/redlineiq.db

# ─── Demo Mode ─────────────────────────────────────────────────
# Set DEMO_MODE=true on public deployments to gate POST /extract
# behind a shared demo key. GET routes (viewing projects) stay public.
# Leave DEMO_MODE unset or false for local development.
DEMO_MODE=false
DEMO_KEY=change_me_before_deploying

# ─── Output (legacy) ───────────────────────────────────────────
# No longer used for persistence (SQLite replaced the JSON file),
# but kept in case you want a specific directory for other output.
OUTPUT_DIR=./output
